      /* Tighten the gap between Sort bar and the products below */
      @media screen and (min-width: 750px) {
        .template-collection .facets-vertical-sort,
        .template-search .facets-vertical-sort {
          margin-top: 0 !important;
          padding-top: 0 !important;
          padding-bottom: 8px !important;
        }
      }

      /* ── Product grid ── */
      /* Keep gaps modest so 4-col doesn't wrap to 3-col on narrower desktops */
      .product-grid.grid--4-col-desktop { gap: 36px 22px !important; }
      .product-grid.grid--3-col-desktop { gap: 48px 32px !important; }
      .product-grid .grid__item { padding-bottom: 8px; }

      /* Mobile: always 2 products per row */
      @media screen and (max-width: 749px) {
        .product-grid.grid--2-col-tablet-down:not(.slider) {
          display: grid !important;
          grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
          column-gap: 14px !important;
          row-gap: 26px !important;
        }
        .product-grid.grid--2-col-tablet-down:not(.slider) > .grid__item {
          width: auto !important;
          max-width: none !important;
        }
      }

      @media screen and (min-width: 990px) {
        /* Force 4 columns even if flex widths get overridden */
        .product-grid.grid--4-col-desktop:not(.slider) {
          display: grid !important;
          grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
          column-gap: 22px !important;
          row-gap: 36px !important;
        }
        .product-grid.grid--4-col-desktop:not(.slider) > .grid__item {
          width: auto !important;
          max-width: none !important;
        }
      }

      /* ── Product card: square / no radius / no inner padding ──
         Wrapper / meta area MUST stay transparent so the page background shows
         through under swatches / title / price. Only the image card gets a
         (non-visible) white background since the photo fills the whole card. */
      .product-grid .card-wrapper,
      .product-grid .card-wrapper--alo,
      .product-grid .card-wrapper--split-alo {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        border-radius: 0 !important;
      }
      .product-grid .card,
      .product-grid .card--media {
        border: none !important;
        box-shadow: none !important;
        background: transparent !important;
        border-radius: 0 !important;
        overflow: hidden;
      }
      .product-grid .grid__item:hover .card {
        transform: none !important;
        box-shadow: none !important;
      }
      /* Meta area (swatches container, title, color name, price) is naked on
         the page bg. We deliberately do NOT touch `.color-swatch` itself —
         each swatch needs its inline background-color: <color> to display the
         color dot. So we only target container / text elements, not "*". */
      .product-grid .grid__item,
      .product-grid .card__alo-meta,
      .product-grid .card__alo-swatches,
      .product-grid .card__alo-color-row,
      .product-grid .card__alo-color-name,
      .product-grid .card__alo-color-status,
      .product-grid .card-information,
      .product-grid .card__heading,
      .product-grid .card__heading a,
      .product-grid .card__content,
      .product-grid .card__information,
      .product-grid .price,
      .product-grid .price__container,
      .product-grid .price__regular,
      .product-grid .price__sale {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
      }
      /* Strip inherited background-image (gradient class on .card) and color
         scheme background that paints the image card white. The photo fills
         the whole card so a transparent card has the same visible result. */
      .product-grid .card,
      .product-grid .card--media,
      .product-grid .card--standard,
      .product-grid .card--card,
      .product-grid .card.gradient,
      .product-grid .card-wrapper.gradient,
      .product-grid .card[class*="color-"] {
        background-image: none !important;
        background-color: transparent !important;
      }

      /* ── Product image: fill the whole card (margin / padding = 0) ── */
      .product-grid .card__inner {
        background: #FFFFFF !important;
        border-radius: 0 !important;
        overflow: hidden;
        aspect-ratio: 1 / 1.1 !important;
        padding: 0 !important;
        margin: 0 !important;
      }
      .product-grid .card__inner .card__media { aspect-ratio: 1 / 1.1 !important; margin: 0 !important; }
      .product-grid .card__media,
      .product-grid .card__media .media {
        aspect-ratio: 1 / 1.1 !important;
        padding: 0 !important;
        margin: 0 !important;
        border-radius: 0 !important;
        display: block !important;
        width: 100% !important;
        height: 100% !important;
      }
      .product-grid .card__media .media img {
        object-fit: cover !important;
        border-radius: 0 !important;
        transform: none !important;
        transition: none !important;
        width: 100% !important;
        height: 100% !important;
        max-height: none !important;
        display: block !important;
      }
      .product-grid .grid__item:hover .card__media .media img {
        transform: none !important;
      }

      /* ── Card content: left aligned ── */
      .product-grid .card__content {
        padding: 16px 20px 20px !important;
        text-align: left !important;
      }
      .product-grid .card__information {
        padding: 0 !important;
        text-align: left !important;
      }

      /* ── Product title (medium weight 550, softer color, left aligned) ── */
      .product-grid .card__heading {
        font-family: var(--font-sans) !important;
        font-size: 14px !important;
        font-weight: 550 !important;
        line-height: 1.45 !important;
        letter-spacing: 0 !important;
        color: #4a5568 !important;
        text-align: left !important;
        max-width: 100% !important;
        margin: 0 0 4px !important;
        padding: 0 !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        display: -webkit-box !important;
        -webkit-line-clamp: 2 !important;
        -webkit-box-orient: vertical !important;
      }
      .product-grid .card__heading a {
        font-weight: 550 !important;
        color: #4a5568 !important;
        text-align: left !important;
        text-decoration: none !important;
        transition: color 0.2s ease !important;
      }
      .product-grid .card__heading a:hover { color: #1f2933 !important; }
      .product-grid .card__heading a::after { display: none !important; }

      /* ── Price ── */
      .product-grid .price,
      .product-grid .price .price-item {
        /* Stronger hierarchy vs product title */
        color: #1F2937 !important;
        font-family: var(--font-sans) !important;
        font-size: 17px !important;
        font-weight: 500 !important;
        letter-spacing: 0.01em !important;
      }
      /* Sale price accent (match reference feel) */
      .product-grid .price__sale .price-item--sale {
        color: #1F9D8A !important;
        font-weight: 600 !important;
      }
      .product-grid .price__sale .price-item--regular {
        color: #9CA3AF !important;
        font-weight: 400 !important;
        font-size: 13px !important;
        text-decoration: line-through !important;
      }
      .product-grid .price__badge,
      .product-grid .badge {
        background: #243B53 !important;
        color: #fff !important;
        border-radius: 6px !important;
        font-size: 10px !important;
        font-weight: 500 !important;
      }

      /* ── Collection hero ── */
      .collection-hero__title {
        font-family: var(--font-serif) !important;
        font-weight: 600 !important;
        letter-spacing: -0.03em !important;
        font-size: clamp(28px, 4vw, 42px) !important;
      }

      /* ── Pagination ── */
      .pagination { font-family: var(--font-sans) !important; margin-top: 24px !important; }
      .pagination a, .pagination span { color: #6B7280 !important; font-weight: 500 !important; }
      .pagination a:hover { color: #243B53 !important; }
      .pagination .current { color: #1F2933 !important; font-weight: 600 !important; }

      /* Product page thumbnails: remove rounded corners completely */
      .template-product .thumbnail.global-media-settings,
      .template-product .thumbnail.global-media-settings img,
      .template-product .thumbnail.global-media-settings iframe,
      .template-product .thumbnail.global-media-settings video,
      .template-product .thumbnail.global-media-settings model-viewer {
        border-radius: 0 !important;
      }
      .template-product .thumbnail.global-media-settings::after,
      .template-product .thumbnail.global-media-settings:after {
        border-radius: 0 !important;
      }

      /* Product variant image pills (Color: Black/Khaki thumbnails): no rounded corners */
      .template-product .product-form__input .label-with-image,
      .template-product .product-form__input .label-with-image::before,
      .template-product .product-form__input .label-with-image img {
        border-radius: 0 !important;
      }

      /* Cart empty state: remove button "border frame" (::after) */
      .cart__warnings .button::after,
      cart-items.is-empty .button::after,
      .is-empty .cart__warnings .button::after {
        content: none !important;
        box-shadow: none !important;
      }

      /* ── Responsive ── */
      @media (min-width: 750px) and (max-width: 989px) {
        .header,
        .collection, .collection.page-width,
        .facets-wrapper.page-width {
          padding-left: var(--site-padding-tablet) !important;
          padding-right: var(--site-padding-tablet) !important;
        }
      }
      @media (max-width: 749px) {
        .header,
        .collection, .collection.page-width,
        .facets-wrapper.page-width {
          padding-left: var(--site-padding-mobile) !important;
          padding-right: var(--site-padding-mobile) !important;
        }
        .product-grid { gap: 28px 16px !important; }
        /* Mobile: image should NOT sit inside a padded card */
        .product-grid .card { border-radius: 0 !important; }
        .product-grid .card__inner { border-radius: 0 !important; background: transparent !important; }
        .product-grid .card__content { padding: 12px 0 16px !important; }
        .product-grid .card__heading { font-size: 14px !important; }
        .product-grid .card__media,
        .product-grid .card__media .media {
          padding: 0 !important;
          margin: 0 !important;
          background: transparent !important;
        }
        .product-grid .card__media .media img {
          transform: none !important;
        }
        .product-grid .grid__item:hover .card__media .media img { transform: none !important; }
        .product-grid .price, .product-grid .price .price-item { font-size: 14px !important; }
      }

      /* ── Back to top button ── */
      .back-to-top {
        position: fixed;
        right: 22px;
        bottom: 22px;
        width: 56px;
        height: 56px;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: rgba(31, 41, 51, 0.92);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 50;
        box-shadow: 0 10px 30px rgba(0,0,0,0.18);
        opacity: 0;
        transform: translateY(8px);
        pointer-events: none;
        transition: opacity 0.2s ease, transform 0.2s ease;
      }
      .back-to-top.is-visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .back-to-top:hover {
        background: rgba(31, 41, 51, 0.98);
      }
      .back-to-top:focus-visible {
        outline: 2px solid rgba(36, 59, 83, 0.65);
        outline-offset: 3px;
      }
      .back-to-top svg {
        width: 22px;
        height: 22px;
        display: block;
      }
      @media (max-width: 749px) {
        .back-to-top {
          right: 16px;
          bottom: 16px;
          width: 52px;
          height: 52px;
        }
      }
    </style>

    {%- unless settings.type_body_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}

    {%- if settings.predictive_search_enabled -%}
      <link rel="stylesheet" href="{{ 'component-predictive-search.css' | asset_url }}" media="print" onload="this.media='all'">
    {%- endif -%}

    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    if (Shopify.designMode) {
      document.documentElement.classList.add('shopify-design-mode');
    }
    </script>
  </head>

  <body class="gradient template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.name | handle }}-{{ template.suffix | handle }}{% endif %}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ "accessibility.skip_to_text" | t }}
    </a>

    {%- if settings.cart_type == 'drawer' -%}
      {%- render 'cart-drawer' -%}
    {%- endif -%}

    {% section 'announcement-bar' %}
    {% section 'header' %}
    {% section 'mega-menu-pro' %}
    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <button class="back-to-top" type="button" aria-label="Back to top" data-back-to-top>
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 5l-7 7m7-7l7 7M12 5v14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}'
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`
      }

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
      }

      window.accessibilityStrings = {
        imageAvailable: `{{ 'products.product.media.image_available' | t: index: '[index]' }}`,
        shareSuccess: `{{ 'general.share.success_message' | t }}`,
        pauseSlideshow: `{{ 'sections.slideshow.pause_slideshow' | t }}`,
        playSlideshow: `{{ 'sections.slideshow.play_slideshow' | t }}`,
      }
    </script>

    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
  </body>
</html>
