      /* ── Filter sidebar: keep each option on a single line ──
         Sidebar is fixed at 200px wide; vertical-mode ul does NOT carry the
         `.facets__list` class (per snippets/facets.liquid), so we target the
         label directly. Force nowrap + a slightly smaller font so labels like
         "Out of stock (10)" never break to 2 lines. */
      /* Desktop sidebar options (rewrite): hard left alignment for Availability etc. */
      .template-collection .facets-vertical .alo-facet-option,
      .template-search .facets-vertical .alo-facet-option {
        position: relative !important;
        display: flex !important;
        align-items: center !important;
        justify-content: flex-start !important;
        gap: 10px !important;
        padding: 6px 0 !important;
        margin: 0 !important;
        font-family: var(--font-sans), 'Inter', -apple-system, BlinkMacSystemFont, sans-serif !important;
        font-size: 14px !important;
        line-height: 1.4 !important;
        color: rgba(17,17,17,0.88) !important;
        text-align: left !important;
        white-space: nowrap !important;
      }
      .template-collection .facets-vertical .alo-facet-option--disabled,
      .template-search .facets-vertical .alo-facet-option--disabled {
        opacity: 0.5 !important;
      }
      .template-collection .facets-vertical .alo-facet-option > input[type='checkbox'],
      .template-search .facets-vertical .alo-facet-option > input[type='checkbox'] {
        position: absolute !important;
        inset: 0 auto auto 0 !important;
        width: 16px !important;
        height: 16px !important;
        opacity: 0 !important;
        margin: 0 !important;
        cursor: pointer !important;
      }
      .template-collection .facets-vertical .alo-facet-option__box,
      .template-search .facets-vertical .alo-facet-option__box {
        width: 16px !important;
        height: 16px !important;
        position: relative !important;
        flex: 0 0 16px !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        color: rgba(17,17,17,0.55) !important;
      }
      .template-collection .facets-vertical .alo-facet-option__box-check,
      .template-search .facets-vertical .alo-facet-option__box-check {
        position: absolute !important;
        inset: 0 !important;
        width: 16px !important;
        height: 16px !important;
        opacity: 0 !important;
      }
      .template-collection .facets-vertical .alo-facet-option > input[type='checkbox']:checked ~ .alo-facet-option__box .alo-facet-option__box-check,
      .template-search .facets-vertical .alo-facet-option > input[type='checkbox']:checked ~ .alo-facet-option__box .alo-facet-option__box-check {
        opacity: 1 !important;
        color: rgba(17,17,17,0.85) !important;
      }
      .template-collection .facets-vertical .alo-facet-option__text,
      .template-search .facets-vertical .alo-facet-option__text {
        flex: 1 1 auto !important;
        min-width: 0 !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        margin: 0 !important;
        padding: 0 !important;
        text-align: left !important;
      }

      .facets-vertical .facet-checkbox,
      .facets-wrapper .facet-checkbox,
      #FacetFiltersForm .facet-checkbox,
      .facets-vertical .facets__item,
      .facets-wrapper .facets__item {
        white-space: nowrap !important;
      }
      .facets-vertical .facet-checkbox,
      .facets-wrapper .facet-checkbox,
      #FacetFiltersForm .facet-checkbox {
        font-size: 12.5px !important;
        line-height: 1.4 !important;
        align-items: center !important;
        gap: 6px !important;
        padding: 6px 0 !important;
        display: flex !important;
        flex-wrap: nowrap !important;
        justify-content: flex-start !important;
        text-align: left !important;
      }
      .facets-vertical .facet-checkbox > *,
      .facets-wrapper .facet-checkbox > *,
      #FacetFiltersForm .facet-checkbox > * {
        white-space: nowrap !important;
      }
      /* Only the checkbox visuals should be non-shrinking.
         Allow the label text to flex so it stays left-aligned. */
      .facets-vertical .facet-checkbox > input[type='checkbox'],
      .facets-wrapper .facet-checkbox > input[type='checkbox'],
      #FacetFiltersForm .facet-checkbox > input[type='checkbox'],
      .facets-vertical .facet-checkbox .facet-checkbox__box,
      .facets-wrapper .facet-checkbox .facet-checkbox__box,
      #FacetFiltersForm .facet-checkbox .facet-checkbox__box {
        flex-shrink: 0 !important;
      }
      /* Only style the visible label text. Do NOT touch `.visually-hidden`,
         otherwise screen-reader-only text becomes visible (bug). */
      .facets-vertical .facet-checkbox span[aria-hidden="true"],
      .facets-wrapper .facet-checkbox span[aria-hidden="true"],
      #FacetFiltersForm .facet-checkbox span[aria-hidden="true"] {
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        font-size: 12.5px !important;
        letter-spacing: 0 !important;
        flex: 1 1 auto !important;
        min-width: 0 !important;
        text-align: left !important;
        margin-left: 0 !important;
      }

      /* Desktop vertical sidebar: remove list padding so option text aligns left. */
      .template-collection .facets-vertical .facets-wrap-vertical > ul,
      .template-search .facets-vertical .facets-wrap-vertical > ul,
      .template-collection .facets-vertical .facets-wrap-vertical > ul.list-unstyled,
      .template-search .facets-vertical .facets-wrap-vertical > ul.list-unstyled {
        padding-left: 0 !important;
        padding-right: 0 !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
      }

      /* Ensure `.visually-hidden` stays hidden even if other rules leak in */
      .facets-vertical .facet-checkbox .visually-hidden,
      .facets-wrapper .facet-checkbox .visually-hidden,
      #FacetFiltersForm .facet-checkbox .visually-hidden {
        position: absolute !important;
        width: 1px !important;
        height: 1px !important;
        padding: 0 !important;
        margin: -1px !important;
        overflow: hidden !important;
        clip: rect(0, 0, 0, 0) !important;
        white-space: nowrap !important;
        border: 0 !important;
      }
      .facets-vertical .facet-checkbox svg,
      .facets-wrapper .facet-checkbox svg,
      #FacetFiltersForm .facet-checkbox svg {
