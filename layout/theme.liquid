      /* Rewritten checkbox visuals (hard-fix centering + thinner checkmark)
         We render a dedicated `.facet-checkbox__box` wrapper in Liquid and
         fully control its layout here, instead of relying on theme's fixed
         absolute top/left offsets. */
      .facets-vertical .facet-checkbox__box {
        width: 1.6rem !important;
        height: 1.6rem !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        position: relative !important;
        margin-right: 0.6rem !important;
        flex: 0 0 auto !important;
