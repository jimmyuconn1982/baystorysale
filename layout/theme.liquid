      /* Container */
      .sort-dropdown-alo {
        position: relative !important;
        display: inline-block !important;
        width: auto !important;
      }

      /* Desktop only: keep dropdown wide enough so options don't truncate */
      @media screen and (min-width: 750px) {
        .sort-dropdown-alo:not(.sort-dropdown-alo--mobile) {
          width: 220px !important;
        }
      }

      /* Trigger ("Sort by ⌃") */
      .sort-dropdown-alo__trigger {
        all: unset !important;
        display: inline-flex !important;
        align-items: center !important;
        gap: 6px !important;
        width: 100% !important;
        justify-content: flex-end !important;
        cursor: pointer !important;
        font-family: var(--font-sans) !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        color: #111111 !important;
        text-decoration: underline !important;
        text-underline-offset: 3px !important;
        line-height: 1.5 !important;
        padding: 4px 2px !important;
      }

      /* Mobile: force boxed "input" look (match reference) */
      @media screen and (max-width: 749px) {
        .sort-dropdown-alo--mobile .sort-dropdown-alo__trigger {
          all: unset !important;
          display: flex !important;
          align-items: center !important;
          justify-content: space-between !important;
          width: 100% !important;
          box-sizing: border-box !important;
          padding: 10px 12px !important;
          background: #ffffff !important;
          border: 1px solid rgba(0,0,0,0.12) !important;
          border-radius: 2px !important;
          font-family: var(--font-sans), 'Inter', -apple-system, BlinkMacSystemFont, sans-serif !important;
          font-size: 12px !important;
          font-weight: 600 !important;
          letter-spacing: 0.08em !important;
          text-transform: uppercase !important;
          color: #111111 !important;
          line-height: 1 !important;
          text-decoration: none !important;
          cursor: pointer !important;
        }
      }
      .sort-dropdown-alo__trigger:hover { opacity: 0.7 !important; }
      .sort-dropdown-alo__trigger .sort-dropdown-alo__caret {
        transition: transform 0.2s ease !important;
      }
      .sort-dropdown-alo__trigger[aria-expanded="true"] .sort-dropdown-alo__caret {
        transform: rotate(180deg) !important;
      }

      /* Panel: a flex column of buttons. Width is fixed so the panel
         never resizes, and box-sizing: border-box makes children's
         widths obey the panel exactly. */
      .sort-dropdown-alo__panel {
        position: absolute !important;
        top: calc(100% + 10px) !important;
        right: 0 !important;
        /* Panel width must NOT exceed the trigger width */
        width: 100% !important;
        box-sizing: border-box !important;
        margin: 0 !important;
        padding: 6px 0 !important;
        background: #FFFFFF !important;
        border: 1px solid rgba(0, 0, 0, 0.06) !important;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.10) !important;
        border-radius: 2px !important;
        z-index: 50 !important;
        display: flex !important;
        flex-direction: column !important;
        align-items: stretch !important;
      }
      .sort-dropdown-alo__panel[hidden] { display: none !important; }

      /* Each option button: width clamped to panel inner width, text
         right-aligned, ellipsis if it ever overflows. */
      .sort-dropdown-alo__option {
        all: unset !important;
        display: block !important;
        box-sizing: border-box !important;
        width: 100% !important;
        max-width: 100% !important;
        padding: 11px 18px !important;
        text-align: right !important;
        font-family: var(--font-sans) !important;
        font-size: 14px !important;
        font-weight: 400 !important;
        color: #5b6166 !important;
        line-height: 1.4 !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        cursor: pointer !important;
        transition: background-color 0.15s ease, color 0.15s ease !important;
      }
      .sort-dropdown-alo__option:hover {
        background: rgba(0, 0, 0, 0.04) !important;
        color: #1f2933 !important;
      }
      .sort-dropdown-alo__option.is-selected {
        background: rgba(0, 0, 0, 0.05) !important;
        color: #1f2933 !important;
        font-weight: 600 !important;
        text-decoration: underline !important;
        text-underline-offset: 3px !important;
