      /* Hide per-filter selected count in the summary (Availability (2) etc.) */
      .facets-vertical .facets__selected {
        display: none !important;
      }

      /* Make the actual <input> clickable area match the 1.6rem box exactly,
         and remove Dawn's negative offsets that can misalign the checkmark. */
      .facets-vertical .facet-checkbox {
        position: relative !important;
      }
      .facets-vertical .facet-checkbox > input[type='checkbox'] {
        position: absolute !important;
        left: 0 !important;
        top: 0 !important;
        width: 1.6rem !important;
        height: 1.6rem !important;
        opacity: 0 !important;
        z-index: 2 !important;
        margin: 0 !important;
        appearance: none !important;
        -webkit-appearance: none !important;
      }

      /* ═════════════════════════════════════════════════════════════════
         Sort by: Alo-style custom dropdown (rewritten)
         ═════════════════════════════════════════════════════════════════ */
      /* Hide the native <select> visually but keep it in the form so
         facets.js can read it on `input` events. */
      .facets-vertical-sort .sort-by-native {
        position: absolute !important;
        width: 1px !important;
        height: 1px !important;
        padding: 0 !important;
        margin: -1px !important;
        overflow: hidden !important;
        clip: rect(0, 0, 0, 0) !important;
        border: 0 !important;
        opacity: 0 !important;
        pointer-events: none !important;
      }
      /* No ancestor should clip the dropdown */
      .facets-vertical-sort,
      .facets-vertical-sort .facets-vertical-form,
      .facets-vertical-sort .facet-filters,
      .facets-vertical-sort .facet-filters__field,
