{% comment %}
    Renders a list of product's price (regular, sale)

    Accepts:
    - product: {Object} Product Liquid object (optional)
    - use_variant: {Boolean} Renders selected or first variant price instead of overall product pricing (optional)
    - show_badges: {Boolean} Renders 'Sale' and 'Sold Out' tags if the product matches the condition (optional)
    - price_class: {String} Adds a price class to the price element (optional)

    Usage:
    {% render 'price', product: product %}
{% endcomment %}
{%- liquid
  if use_variant
    assign target = product.selected_or_first_available_variant
  else
    assign target = product
  endif

  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 1999
  assign available = target.available | default: false
  assign money_price = price | money
  assign money_price_separator = '.'
  assign money_price_parts = money_price | split: money_price_separator

  unless money_price contains money_price_separator
    assign money_price_separator = ','
    assign money_price_parts = money_price | split: money_price_separator
  endunless

  assign compare_money_price = compare_at_price | money
  assign compare_money_price_separator = '.'
  assign compare_money_price_parts = compare_money_price | split: compare_money_price_separator

  unless compare_money_price contains compare_money_price_separator
    assign compare_money_price_separator = ','
    assign compare_money_price_parts = compare_money_price | split: compare_money_price_separator
  endunless

  if target == product and product.price_varies
    assign money_price = 'products.product.price.from_price_html' | t: price: money_price
    assign money_price_separator = '.'
    assign money_price_parts = money_price | split: money_price_separator

    unless money_price contains money_price_separator
      assign money_price_separator = ','
      assign money_price_parts = money_price | split: money_price_separator
    endunless
  endif
-%}

<div class="price
  {%- if price_class %} {{ price_class }}{% endif -%}
  {%- if available == false %} price--sold-out {% endif -%}
  {%- if compare_at_price > price %} price--on-sale {% endif -%}
  {%- if product.price_varies == false and product.compare_at_price_varies %} price--no-compare{% endif -%}
  {%- if show_badges %} price--show-badge{% endif -%}">
  <div class="price__container">
    {%- comment -%}
      Explanation of description list:
        - div.price__regular: Displayed when there are no variants on sale
        - div.price__sale: Displayed when a variant is a sale
    {%- endcomment -%}
    <div class="price__regular">
      <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.regular_price' | t }}</span>
      <span class="price-item price-item--regular" style="color: #b12739; font-weight: bold;">
        {%- if money_price_parts.size > 1 -%}
          <span class="price-item__main">{{ money_price_parts[0] }}{{ money_price_separator }}</span><sup class="price-item__cents">{{ money_price_parts[1] }}</sup>
        {%- else -%}
          {{ money_price }}
        {%- endif -%}
      </span>
    </div>
    <div class="price__sale">
      <div class="price__sale-wrapper" style="display: flex; flex-direction: row; align-items: baseline; gap: 8px; justify-content: center;">
      <div class="price__sale-current" style="display: flex; align-items: center; gap: 8px;">
        <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.sale_price' | t }}</span>
        <span class="price-item price-item--sale price-item--last" style="color: #b12739; font-size: 2.4rem; font-weight: bold; margin: 0; line-height: 1;">
          {%- if money_price_parts.size > 1 -%}
            <span class="price-item__main">{{ money_price_parts[0] }}{{ money_price_separator }}</span><sup class="price-item__cents">{{ money_price_parts[1] }}</sup>
          {%- else -%}
            {{ money_price }}
          {%- endif -%}
        </span>
        
      </div>

      {%- unless product.price_varies == false and product.compare_at_price_varies %}
        <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.regular_price' | t }}</span>
        <span class="price__sale-compare" style="display: flex; align-items: center; gap: 4px; color: #737373; font-size: 1.4rem; line-height: 1;">
          <s class="price-item price-item--regular" style="color: inherit; margin: 0;">
            {%- if compare_money_price_parts.size > 1 -%}
              <span class="price-item__main">{{ compare_money_price_parts[0] }}{{ compare_money_price_separator }}</span><sup class="price-item__cents">{{ compare_money_price_parts[1] }}</sup>
            {%- else -%}
              {{ compare_money_price }}
            {%- endif -%}
          </s>
          {%- if price_class contains 'price--large' -%}
          <span class="price-info-tooltip-wrapper" style="position: relative; display: inline-flex; align-items: center; cursor: pointer;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #2b5bc1; margin-top: 1px;">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="16" x2="12" y2="12"></line>
              <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
            <span class="price-info-tooltip" style="position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); width: 260px; background: #f0f0f0; color: #222; padding: 12px; border: 1px solid #ccc; border-radius: 4px; box-shadow: 0 4px 10px rgba(0,0,0,0.15); font-size: 1.3rem; line-height: 1.4; text-align: left; opacity: 0; visibility: hidden; transition: opacity 0.2s, visibility 0.2s; z-index: 10; margin-bottom: 8px; font-weight: normal; font-family: inherit;">
              This is the List Price. The List Price is the suggested retail price from a manufacturer, supplier, or other retailer. It may not necessarily reflect an actual price offered on our site or elsewhere.
              <span style="position: absolute; top: 100%; left: 50%; transform: translateX(-50%); border-width: 7px; border-style: solid; border-color: #ccc transparent transparent transparent;"></span>
              <span style="position: absolute; top: 100%; left: 50%; transform: translateX(-50%); border-width: 6px; border-style: solid; border-color: #f0f0f0 transparent transparent transparent; margin-top: -2px;"></span>
            </span>
          </span>
          <style>
            .price-info-tooltip-wrapper:hover .price-info-tooltip { opacity: 1 !important; visibility: visible !important; }
          </style>
          {%- endif -%}
        </span>
      {%- endunless -%}
      </div>
    </div>
    <small class="unit-price caption{% if product.selected_or_first_available_variant.unit_price_measurement == nil %} hidden{% endif %}">
      <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
      <span class="price-item price-item--last">
        <span>{{- product.selected_or_first_available_variant.unit_price | money -}}</span>
        <span aria-hidden="true">/</span>
        <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
        <span>
          {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value != 1 -%}
            {{- product.selected_or_first_available_variant.unit_price_measurement.reference_value -}}
          {%- endif -%}
          {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
        </span>
      </span>
    </small>
  </div>
  {%- if show_badges -%}
    <span class="badge price__badge-sale color-{{ settings.sale_badge_color_scheme }}" style="display: none;">
      {{ 'products.product.on_sale' | t }}
    </span>

    <span class="badge price__badge-sold-out color-{{ settings.sold_out_badge_color_scheme }}">
      {{ 'products.product.sold_out' | t }}
    </span>
  {%- endif -%}
</div>
