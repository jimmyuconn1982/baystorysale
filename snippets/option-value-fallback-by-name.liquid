{%- comment -%}
  When taxonomy / swatch API returns missing or misleading colors, map common option names to a solid fill.
  Accepts: color_name (string)
  Outputs: CSS fragment e.g. `background-color: #3d7a45;` or blank if unknown.
{%- endcomment -%}
{%- assign n = color_name | downcase | strip -%}
{%- case n -%}
  {%- when 'black' -%}background-color: #1a1a1a;
  {%- when 'white', 'off white', 'off-white', 'ivory', 'cream', 'snow', 'pearl' -%}background-color: #f5f5f5;
  {%- when 'gray', 'grey', 'light gray', 'light grey', 'dark gray', 'dark grey', 'charcoal', 'silver' -%}background-color: #9ca3af;
  {%- when 'red', 'burgundy', 'wine', 'maroon' -%}background-color: #b91c1c;
  {%- when 'blue', 'navy', 'royal blue', 'dark blue', 'light blue' -%}background-color: #1d4ed8;
  {%- when 'green', 'olive', 'olive green', 'army green', 'sage', 'mint' -%}background-color: #3d7a45;
  {%- when 'yellow', 'gold', 'mustard' -%}background-color: #d4a017;
  {%- when 'orange', 'coral', 'peach' -%}background-color: #ea580c;
  {%- when 'pink', 'rose', 'blush' -%}background-color: #ec4899;
  {%- when 'purple', 'violet', 'lavender' -%}background-color: #7c3aed;
  {%- when 'brown', 'tan', 'coffee', 'chocolate', 'espresso' -%}background-color: #78350f;
  {%- when 'beige', 'nude', 'taupe' -%}background-color: #d6c4a8;
  {%- when 'khaki' -%}background-color: #c3b091;
{%- endcase -%}
