{%- comment -%}
  Top header: Shop + Primary Category dropdowns + About.

  Data model (must be on **collections**, not only products — Liquid cannot scan all products):
  - `custom.primary_category` — same value as on products (e.g. Handbags). Single value or list.
  - `custom.sub_category` — optional; shown as the dropdown link label (e.g. Crossbody Bags).
    If blank, the collection title is used.

  Each row in the menu = one collection URL → that collection’s products (smart collection rules can mirror product metafields).

  顶栏结构：Shop | 所有 Primary 列 | About。主类顺序：主题设置 →「Primary category order menu」选择导航菜单
  即可在后台拖拽排序（见 config/settings_schema.json）；未选菜单时用 preferred_primary_order 默认顺序，并追加未列主类。
{%- endcomment -%}

{%- liquid
  assign new_arrivals_url = collections['new-arrivals'].url | default: '/collections/new-arrivals'
  assign best_sellers_url = collections['best-sellers'].url
  if best_sellers_url == blank
    assign best_sellers_url = collections['best-seller'].url
  endif
  if best_sellers_url == blank
    assign best_sellers_url = collections['bestsellers'].url
  endif
  if best_sellers_url == blank
    assign best_sellers_url = collections['bestseller'].url
  endif
  if best_sellers_url == blank
    assign best_sellers_url = '/collections/best-sellers'
  endif
  assign shop_all_url = '/collections/all'
  assign about_us_url = '/pages/about-us'

  assign preferred_primary_order = 'Handbags,Backpacks,Travel Bags,Pet Carriers' | split: ','
-%}
{%- capture _primary_nav_order_csv -%}
  {%- render 'primary-nav-order-csv',
    category_menu_collections: category_menu_collections,
    preferred_primary_order: preferred_primary_order,
    primary_category_order_menu: settings.primary_category_order_menu
  -%}
{%- endcapture -%}
{%- assign final_primary_nav_labels = _primary_nav_order_csv | strip | split: '###' -%}

{%- comment -%} ---------- Mobile ---------- {%- endcomment -%}
{%- if code_menu_mode == 'mobile' -%}
  <li>
    <details id="Details-menu-drawer-shop">
      <summary class="menu-drawer__menu-item list-menu__item link link--text focus-inset">
        Shop
        <span class="menu-drawer__submenu-toggle mobile-accordion-toggle" aria-hidden="true">
          {% render 'icon-caret' %}
        </span>
      </summary>
      <div class="mobile-accordion-submenu" tabindex="-1">
        <ul class="menu-drawer__menu list-menu" role="list">
          <li>
            <a href="{{ shop_all_url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset">All Products</a>
          </li>
          <li>
            <a href="{{ new_arrivals_url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset">New Arrivals</a>
          </li>
          <li>
            <a href="{{ best_sellers_url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset">Best Sellers</a>
          </li>
        </ul>
      </div>
    </details>
  </li>
  {%- if category_menu_collections != blank -%}
    {%- for primary_label_clean in final_primary_nav_labels -%}
      {%- if primary_label_clean == blank -%}{%- continue -%}{%- endif -%}
      {%- assign primary_category_key = primary_label_clean | downcase -%}
      {%- assign primary_category_token = '||' | append: primary_category_key | append: '||' -%}
      {%- assign primary_category_handle = primary_label_clean | handleize -%}
      {%- assign has_children = false -%}
      {%- for category_collection in category_menu_collections -%}
        {%- assign pc_mf = category_collection.metafields.custom.primary_category -%}
        {%- if pc_mf != blank -%}
          {%- liquid
            assign _pk = ''
            if pc_mf.type contains 'list.'
              assign _pv = pc_mf.value | join: '||'
            else
              assign _pv = pc_mf.value
            endif
            assign _pv = _pv | replace: ' • ', '||' | replace: '•', '||' | replace: ', ', '||' | replace: ',', '||' | replace: '; ', '||' | replace: ';', '||'
            assign _plist = _pv | split: '||'
          -%}
          {%- for _p in _plist -%}
            {%- assign _k = _p | strip | downcase -%}
            {%- if _k == primary_category_key -%}
              {%- assign has_children = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
        {%- if has_children -%}{%- break -%}{%- endif -%}
      {%- endfor -%}
      {%- if has_children -%}
        <li>
          <details id="Details-menu-drawer-primary-{{ primary_category_handle }}">
            <summary class="menu-drawer__menu-item list-menu__item link link--text focus-inset">
              {{ primary_label_clean | escape }}
              <span class="menu-drawer__submenu-toggle mobile-accordion-toggle" aria-hidden="true">{% render 'icon-caret' %}</span>
            </summary>
            <div class="mobile-accordion-submenu" tabindex="-1">
              <ul class="menu-drawer__menu list-menu" role="list">
                {%- capture shop_all_primary_url -%}{%- render 'shop-all-url-for-primary', primary_label_clean: primary_label_clean, category_menu_collections: category_menu_collections -%}{%- endcapture -%}
                <li>
                  <a href="{{ shop_all_primary_url | strip }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset menu__shop-all-primary">
                    Shop All {{ primary_label_clean | escape }}
                  </a>
                </li>
                {%- for child_collection in category_menu_collections -%}
                  {%- assign child_pc = child_collection.metafields.custom.primary_category -%}
                  {%- if child_pc == blank -%}{%- continue -%}{%- endif -%}
                  {%- liquid
                    assign child_primary_category_keys = ''
                    if child_pc.type contains 'list.'
                      assign child_primary_category_values = child_pc.value | join: '||'
                    else
                      assign child_primary_category_values = child_pc.value
                    endif
                    assign child_primary_category_values = child_primary_category_values | replace: ' • ', '||' | replace: '•', '||' | replace: ', ', '||' | replace: ',', '||' | replace: '; ', '||' | replace: ';', '||'
                    assign child_primary_category_list = child_primary_category_values | split: '||'
                  -%}
                  {%- for child_primary_category in child_primary_category_list -%}
                    {%- assign child_primary_category_key = child_primary_category | strip | downcase -%}
                    {%- if child_primary_category_key != blank -%}
                      {%- assign child_primary_category_keys = child_primary_category_keys | append: '||' | append: child_primary_category_key | append: '||' -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if child_primary_category_keys contains primary_category_token -%}
                    {%- assign nav_link_label = child_collection.title -%}
                    {%- assign sub_mf = child_collection.metafields.custom.sub_category -%}
                    {%- if sub_mf != blank -%}
                      {%- if sub_mf.type contains 'list.' -%}
                        {%- assign nav_link_label = sub_mf.value | join: ', ' -%}
                      {%- else -%}
                        {%- assign nav_link_label = sub_mf.value -%}
                      {%- endif -%}
                    {%- endif -%}
                    <li>
                      <a href="{{ child_collection.url }}" class="menu-drawer__menu-item link link--text list-menu__item focus-inset">
                        {{ nav_link_label | escape }}
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          </details>
        </li>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  <li>
    <a href="{{ about_us_url }}" class="menu-drawer__menu-item list-menu__item link link--text focus-inset">About</a>
  </li>

{%- comment -%} ---------- Desktop ---------- {%- endcomment -%}
{%- else -%}
  <li>
    <header-menu>
      <details id="Details-HeaderMenu-Shop">
        <summary class="header__menu-item list-menu__item link focus-inset">
          <span>Shop</span>
          {% render 'icon-caret' %}
        </summary>
        <ul id="HeaderMenu-Shop" class="header__submenu list-menu list-menu--disclosure gradient caption-large motion-reduce global-settings-popup" role="list" tabindex="-1">
          <li>
            <a href="{{ shop_all_url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large">All Products</a>
          </li>
          <li>
            <a href="{{ new_arrivals_url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large">New Arrivals</a>
          </li>
          <li>
            <a href="{{ best_sellers_url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large">Best Sellers</a>
          </li>
        </ul>
      </details>
    </header-menu>
  </li>
  {%- if category_menu_collections != blank -%}
    {%- for primary_label_clean in final_primary_nav_labels -%}
      {%- if primary_label_clean == blank -%}{%- continue -%}{%- endif -%}
      {%- assign primary_category_key = primary_label_clean | downcase -%}
      {%- assign primary_category_token = '||' | append: primary_category_key | append: '||' -%}
      {%- assign primary_category_handle = primary_label_clean | handleize -%}
      {%- assign has_children = false -%}
      {%- for category_collection in category_menu_collections -%}
        {%- assign pc_mf = category_collection.metafields.custom.primary_category -%}
        {%- if pc_mf != blank -%}
          {%- liquid
            assign _pk = ''
            if pc_mf.type contains 'list.'
              assign _pv = pc_mf.value | join: '||'
            else
              assign _pv = pc_mf.value
            endif
            assign _pv = _pv | replace: ' • ', '||' | replace: '•', '||' | replace: ', ', '||' | replace: ',', '||' | replace: '; ', '||' | replace: ';', '||'
            assign _plist = _pv | split: '||'
          -%}
          {%- for _p in _plist -%}
            {%- assign _k = _p | strip | downcase -%}
            {%- if _k == primary_category_key -%}
              {%- assign has_children = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
        {%- if has_children -%}{%- break -%}{%- endif -%}
      {%- endfor -%}
      {%- if has_children -%}
        <li>
          <header-menu>
            <details id="Details-HeaderMenu-Primary-{{ primary_category_handle }}">
              <summary class="header__menu-item list-menu__item link focus-inset">
                <span>{{ primary_label_clean | escape }}</span>
                {% render 'icon-caret' %}
              </summary>
              <ul id="HeaderMenu-Primary-{{ primary_category_handle }}" class="header__submenu list-menu list-menu--disclosure gradient caption-large motion-reduce global-settings-popup" role="list" tabindex="-1">
                {%- capture shop_all_primary_url -%}{%- render 'shop-all-url-for-primary', primary_label_clean: primary_label_clean, category_menu_collections: category_menu_collections -%}{%- endcapture -%}
                <li>
                  <a href="{{ shop_all_primary_url | strip }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large menu__shop-all-primary">
                    Shop All {{ primary_label_clean | escape }}
                  </a>
                </li>
                {%- for child_collection in category_menu_collections -%}
                  {%- assign child_pc = child_collection.metafields.custom.primary_category -%}
                  {%- if child_pc == blank -%}{%- continue -%}{%- endif -%}
                  {%- liquid
                    assign child_primary_category_keys = ''
                    if child_pc.type contains 'list.'
                      assign child_primary_category_values = child_pc.value | join: '||'
                    else
                      assign child_primary_category_values = child_pc.value
                    endif
                    assign child_primary_category_values = child_primary_category_values | replace: ' • ', '||' | replace: '•', '||' | replace: ', ', '||' | replace: ',', '||' | replace: '; ', '||' | replace: ';', '||'
                    assign child_primary_category_list = child_primary_category_values | split: '||'
                  -%}
                  {%- for child_primary_category in child_primary_category_list -%}
                    {%- assign child_primary_category_key = child_primary_category | strip | downcase -%}
                    {%- if child_primary_category_key != blank -%}
                      {%- assign child_primary_category_keys = child_primary_category_keys | append: '||' | append: child_primary_category_key | append: '||' -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if child_primary_category_keys contains primary_category_token -%}
                    {%- assign nav_link_label = child_collection.title -%}
                    {%- assign sub_mf = child_collection.metafields.custom.sub_category -%}
                    {%- if sub_mf != blank -%}
                      {%- if sub_mf.type contains 'list.' -%}
                        {%- assign nav_link_label = sub_mf.value | join: ', ' -%}
                      {%- else -%}
                        {%- assign nav_link_label = sub_mf.value -%}
                      {%- endif -%}
                    {%- endif -%}
                    <li>
                      <a href="{{ child_collection.url }}" class="header__menu-item list-menu__item link link--text focus-inset caption-large">
                        {{ nav_link_label | escape }}
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </details>
          </header-menu>
        </li>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  <li>
    <a href="{{ about_us_url }}" class="header__menu-item list-menu__item link link--text focus-inset">
      <span>About</span>
    </a>
  </li>
{%- endif -%}
