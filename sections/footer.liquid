{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-list-payment.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-social.css' | asset_url }}" media="print" onload="this.media='all'">

<noscript>{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-list-social.css' | asset_url | stylesheet_tag }}</noscript>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

  .footer-premium {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #1F2937;
    color: rgba(255, 255, 255, 0.96);
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }

  /* Ensure footer headings stay visible (override global heading color !important) */
  .footer-premium h1,
  .footer-premium h2,
  .footer-premium h3,
  .footer-premium h4,
  .footer-premium h5,
  .footer-premium h6,
  .footer-premium .h0,
  .footer-premium .h1,
  .footer-premium .h2,
  .footer-premium .h3,
  .footer-premium .h4,
  .footer-premium .h5,
  .footer-premium .hxl {
    color: rgba(255, 255, 255, 0.96) !important;
  }

  /* ── Newsletter: centered container, left-aligned content ── */
  .fp-newsletter {
    padding: 56px 24px 48px;
    border-bottom: 1px solid rgba(255,255,255,0.14);
  }
  .fp-newsletter__inner {
    max-width: 440px;
    margin: 0 auto;
    text-align: left;
  }
  .fp-newsletter__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.96);
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .fp-newsletter__subtitle {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.82);
    margin: 0 0 28px;
    font-weight: 400;
    letter-spacing: 0.1px;
  }
  .fp-newsletter__form {
    display: flex;
    margin: 0;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.26);
    border-radius: 2px;
    overflow: hidden;
    background: rgba(255,255,255,0.10);
    transition: border-color 0.2s;
  }
  .fp-newsletter__form:focus-within {
    border-color: rgba(255,255,255,0.55);
  }
  .fp-newsletter__input {
    flex: 1;
    border: none;
    outline: none;
    padding: 14px 18px;
    font-size: 14px;
    font-family: inherit;
    color: rgba(255, 255, 255, 0.92);
    background: transparent;
    border-radius: 0;
    min-width: 0;
  }
  .fp-newsletter__input::placeholder { color: rgba(255,255,255,0.62); }
  .fp-newsletter__btn {
    background: #ffffff;
    color: #111827;
    border: none;
    padding: 14px 22px;
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    letter-spacing: 0.3px;
    white-space: nowrap;
    transition: background 0.2s ease;
    border-radius: 0;
  }
  .fp-newsletter__btn:hover { background: rgba(255,255,255,0.92); }
  .fp-newsletter__disclaimer {
    font-size: 11px;
    color: rgba(255,255,255,0.62);
    margin: 12px 0 0;
    letter-spacing: 0.2px;
    line-height: 1.55;
    max-width: 380px;
  }

  /* ── Main grid: asymmetric ── */
  .fp-grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 44px 24px 36px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.2fr 1.6fr;
    gap: 24px;
    align-items: start;
  }

  /* ── Column headings (Quick links / Shop / Why BaystoryBag) ──
     Typography unification: keep everything on Inter, and reduce the heavy
     small-caps spacing so headings don't look like a different font. */
  .fp-col__heading {
    font-family: var(--font-sans), 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.92) !important;
    margin: 0 0 16px;
    line-height: 1.3;
  }
  /* Brand title gets the same family but is sized to read as the brand
     statement rather than a section label. */
  .fp-col__heading--brand {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.96) !important;
    margin-bottom: 14px;
    line-height: 1.4;
  }

  /* ── Brand column body ── */
  .fp-col--brand .fp-brand-text,
  .fp-col--brand .fp-brand-text p {
    font-family: var(--font-sans), 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.72);
    line-height: 1.7;
    margin: 0;
    letter-spacing: 0.1px;
    font-weight: 400;
  }

  /* ── Social ── */
  .fp-social {
    display: flex;
    gap: 14px;
    margin-top: 20px;
  }
  .fp-social a {
    color: rgba(255,255,255,0.80);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }
  .fp-social a:hover { color: rgba(255,255,255,0.92); }
  .fp-social svg { width: 16px; height: 16px; }

  /* ── Link lists ── */
  .fp-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .fp-links a {
    font-size: 13px;
    color: rgba(255,255,255,0.80);
    text-decoration: none;
    letter-spacing: 0;
    transition: color 0.2s ease;
    line-height: 1.5;
  }
  .fp-links a:hover { color: rgba(255,255,255,0.92); }

  .fp-newsletter__title,
  .fp-newsletter__subtitle,
  .fp-brand-text,
  .fp-brand-text p,
  .fp-trust__item,
  .fp-bottom__copy {
    text-shadow: 0 1px 0 rgba(0,0,0,0.18);
  }

  /* ── Trust badges ── */
  .fp-trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .fp-trust__item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: rgba(255,255,255,0.80);
    letter-spacing: 0;
    line-height: 1.4;
  }

  /* Ensure non-newsletter footer content is consistently Inter */
  .fp-grid > .fp-col:not(.fp-newsletter) *,
  .fp-grid > .fp-col.fp-col--brand * {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  .fp-trust__icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    color: rgba(255,255,255,0.85);
    opacity: 0.45;
  }

  /* ── Bottom bar ── */
  .fp-bottom {
    border-top: 1px solid rgba(255,255,255,0.14);
    padding: 18px 24px;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .fp-bottom__copy {
    font-size: 12px;
    color: rgba(255,255,255,0.72);
    letter-spacing: 0.2px;
  }
  .fp-bottom__copy a { color: rgba(255,255,255,0.84); text-decoration: none; }
  .fp-bottom__copy a:hover { color: rgba(255,255,255,0.92); }
  .fp-bottom__pay ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .fp-bottom__pay .icon { width: 36px; height: 22px; }

  /* ── Responsive ── */
  @media (max-width: 989px) {
    .fp-grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px 20px;
      padding: 36px 24px 28px;
    }
    .fp-col--brand { grid-column: 1 / -1; }
    .fp-newsletter { padding: 44px 24px 36px; }
    .fp-newsletter__title { font-size: 20px; }
  }
  @media (max-width: 599px) {
    /* Mobile footer uses a dedicated accordion layout (fp-mobile) */
    .fp-grid { display: none !important; }
    .fp-mobile { display: block !important; }
    .fp-newsletter--right { display: none !important; }

    .fp-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 32px 20px 24px;
    }
    .fp-newsletter { padding: 36px 20px 28px; }
    .fp-newsletter__form { flex-direction: column; border-radius: 10px; }
    .fp-newsletter__input { padding: 13px 16px; }
    .fp-newsletter__btn { padding: 13px; border-radius: 0; }
    .fp-bottom { padding: 16px 20px; }
    .fp-bottom { flex-direction: column; align-items: flex-start; }
  }

  /* Mobile-only footer layout (accordion, newsletter first) */
  .fp-mobile { display: none; }
  @media (max-width: 599px) {
    .fp-mobile {
      padding: 26px 20px 10px;
    }
    .fp-mobile .fp-col__heading--brand { margin-bottom: 10px; }
    .fp-mobile .fp-brand-text { margin-bottom: 18px; }

    .fp-mobile .fp-newsletter {
      padding: 0 0 18px;
      border-bottom: 0;
      margin-bottom: 14px;
    }
    .fp-mobile .fp-newsletter__inner { max-width: none; margin: 0; }
    .fp-mobile .fp-newsletter__title {
      font-family: var(--font-sans), 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 18px;
      font-weight: 600;
      letter-spacing: 0;
      margin: 0 0 6px;
    }
    .fp-mobile .fp-newsletter__subtitle { margin: 0 0 14px; }
    /* Mobile newsletter form should stay ONE ROW (match reference) */
    .fp-mobile .fp-newsletter__form {
      flex-direction: row !important;
      border-radius: 6px !important;
    }
    .fp-mobile .fp-newsletter__input {
      padding: 12px 14px !important;
    }
    .fp-mobile .fp-newsletter__btn {
      width: auto !important;
      padding: 12px 16px !important;
      min-width: 96px;
    }

    .fp-acc {
      border-bottom: 0;
      padding: 10px 0;
    }
    .fp-acc summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 0;
    }
    .fp-acc summary::-webkit-details-marker { display: none; }
    .fp-acc__title {
      font-family: var(--font-sans), 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.92);
    }
    .fp-acc__caret {
      width: 10px;
      height: 10px;
      opacity: 0.85;
      transition: transform 160ms ease;
    }
    .fp-acc[open] .fp-acc__caret { transform: rotate(180deg); }
    .fp-acc__body { padding: 0 0 14px; }
    .fp-acc__body .fp-links { gap: 10px; }
  }

  /* ── Form messages ── */
  .fp-newsletter .newsletter-form__message {
    font-size: 12px;
    margin-top: 8px;
  }
  .fp-newsletter .form__message { font-size: 12px; }

  /* hide original Dawn footer elements we don't need */
  .fp-newsletter .field__label { display: none !important; }
  .fp-newsletter .field:after,
  .fp-newsletter .field:before { content: none !important; }

  /* Newsletter when placed on the right column */
  .fp-newsletter--right {
    padding: 0;
    border-bottom: none;
  }
  .fp-newsletter--right .fp-newsletter__inner {
    max-width: none;
    margin: 0;
  }
</style>

<footer class="footer-premium">

  {%- comment -%} ─── Mobile footer (accordion + newsletter first) ─── {%- endcomment -%}
  <div class="fp-mobile">
    {%- assign brand_block = section.blocks | where: 'type', 'text' | first -%}
    {%- assign links_block = section.blocks | where: 'type', 'link_list' | first -%}

    {%- if section.settings.newsletter_enable -%}
      <div class="fp-newsletter">
        <div class="fp-newsletter__inner">
          <h2 class="fp-newsletter__title">Get 15% Off Your First Order</h2>
          <p class="fp-newsletter__subtitle">Get updates on new products, promotion offers.</p>
          {%- form 'customer', id: 'ContactFooterMobile', class: 'newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="fp-newsletter__form">
              <input
                id="NewsletterFormMobile--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="fp-newsletter__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}autofocus aria-invalid="true" aria-describedby="ContactFooterMobile-error"{% elsif form.posted_successfully? %}aria-describedby="ContactFooterMobile-success"{% endif %}
                placeholder="Your email address"
                required
              >
              <button type="submit" class="fp-newsletter__btn" name="commit" aria-label="Subscribe">Subscribe</button>
            </div>
            <p class="fp-newsletter__disclaimer">By entering your email address, you agree to our Privacy Policy and will receive BaystoryBag offers, promotions and other commercial messages. You may unsubscribe at any time.</p>
          {%- endform -%}
        </div>
      </div>
    {%- endif -%}

    {%- if brand_block -%}
      <h3 class="fp-col__heading fp-col__heading--brand">{{ brand_block.settings.heading | escape }}</h3>
      <div class="fp-brand-text rte">{{ brand_block.settings.subtext }}</div>
    {%- endif -%}

    <details class="fp-acc">
      <summary>
        <span class="fp-acc__title">Quick links</span>
        <svg class="fp-acc__caret" viewBox="0 0 10 6" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </summary>
      <div class="fp-acc__body">
        <ul class="fp-links">
          {%- if links_block -%}
            {%- for link in links_block.settings.menu.links -%}
              {%- if link.title == "Search" or link.title == "搜索" or link.title == "Shipping Policy" or link.title == "Refund Policy" or link.title == "退款政策" or link.title == "退換貨政策" -%}{%- continue -%}{%- endif -%}
              <li><a {% assign link_title_clean = link.title | strip | downcase %}{% if link_title_clean == "about us" %}href="/pages/about-us"{% else %}href="{{ link.url }}"{% endif %} class="link--text{% if link.active %} list-menu__item--active{% endif %}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- endif -%}
          <li><a href="/pages/faq" class="link--text">FAQ</a></li>
          <li><a href="/pages/contact" class="link--text">Contact</a></li>
          <li><a href="{{ routes.root_url }}policies/privacy-policy" class="link--text">Privacy</a></li>
          <li><a href="{{ routes.root_url }}policies/terms-of-service" class="link--text">Terms</a></li>
        </ul>
      </div>
    </details>

    <details class="fp-acc">
      <summary>
        <span class="fp-acc__title">Shop</span>
        <svg class="fp-acc__caret" viewBox="0 0 10 6" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </summary>
      <div class="fp-acc__body">
        <ul class="fp-links">
          {% render 'footer-shop-primary-list' %}
        </ul>
      </div>
    </details>

    <details class="fp-acc">
      <summary>
        <span class="fp-acc__title">Why BaystoryBag</span>
        <svg class="fp-acc__caret" viewBox="0 0 10 6" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </summary>
      <div class="fp-acc__body">
        <ul class="fp-trust">
          <li class="fp-trust__item"><svg class="fp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg><span>Fast U.S. Shipping</span></li>
          <li class="fp-trust__item"><svg class="fp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg><span>Secure Checkout</span></li>
          <li class="fp-trust__item"><svg class="fp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg><span>Easy Returns</span></li>
          <li class="fp-trust__item"><svg class="fp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg><span>Pet-Friendly Travel Essentials</span></li>
        </ul>
      </div>
    </details>
  </div>

  {%- comment -%} ─── Main Grid (asymmetric 4-col) ─── {%- endcomment -%}
  <div class="fp-grid">

    {%- comment -%} Col 1 — Brand (wide) {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'text' -%}
      <div class="fp-col fp-col--brand" {{ block.shopify_attributes }}>
        <h3 class="fp-col__heading fp-col__heading--brand">{{ block.settings.heading | escape }}</h3>
        <div class="fp-brand-text rte">{{ block.settings.subtext }}</div>
        {%- if section.settings.show_social -%}
        <div class="fp-social">
          {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" aria-label="Instagram">{%- render 'icon-instagram' -%}</a>{%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}<a href="{{ settings.social_tiktok_link }}" aria-label="TikTok">{%- render 'icon-tiktok' -%}</a>{%- endif -%}
          {%- if settings.social_facebook_link != blank -%}<a href="{{ settings.social_facebook_link }}" aria-label="Facebook">{%- render 'icon-facebook' -%}</a>{%- endif -%}
          {%- if settings.social_twitter_link != blank -%}<a href="{{ settings.social_twitter_link }}" aria-label="Twitter">{%- render 'icon-twitter' -%}</a>{%- endif -%}
          {%- if settings.social_pinterest_link != blank -%}<a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest">{%- render 'icon-pinterest' -%}</a>{%- endif -%}
          {%- if settings.social_youtube_link != blank -%}<a href="{{ settings.social_youtube_link }}" aria-label="YouTube">{%- render 'icon-youtube' -%}</a>{%- endif -%}
        </div>
        {%- endif -%}
      </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Col 2 — Quick Links {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
      <div class="fp-col" {{ block.shopify_attributes }}>
        <h3 class="fp-col__heading">{{ block.settings.heading | escape }}</h3>
        <ul class="fp-links">
          {%- for link in block.settings.menu.links -%}
            {%- if link.title == "Search" or link.title == "搜索" or link.title == "Shipping Policy" or link.title == "Refund Policy" or link.title == "退款政策" or link.title == "退換貨政策" -%}{%- continue -%}{%- endif -%}
            <li>
              <a {% assign link_title_clean = link.title | strip | downcase %}{% if link_title_clean == "about us" %}href="/pages/about-us"{% else %}href="{{ link.url }}"{% endif %} class="link--text{% if link.active %} list-menu__item--active{% endif %}">{{ link.title }}</a>
            </li>
          {%- endfor -%}
          <li><a href="/pages/faq" class="link--text">FAQ</a></li>
          <li><a href="/pages/contact" class="link--text">Contact</a></li>
          <li><a href="{{ routes.root_url }}policies/privacy-policy" class="link--text">Privacy</a></li>
          <li><a href="{{ routes.root_url }}policies/terms-of-service" class="link--text">Terms</a></li>
        </ul>
      </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Col 3 — Shop {%- endcomment -%}
    <div class="fp-col">
      <h3 class="fp-col__heading">Shop</h3>
      <ul class="fp-links">
        {% render 'footer-shop-primary-list' %}
      </ul>
    </div>

    {%- comment -%} Col 4 — Trust badges (wide) {%- endcomment -%}
    <div class="fp-col">
      <h3 class="fp-col__heading">Why BaystoryBag</h3>
      <ul class="fp-trust">
        <li class="fp-trust__item">
          <svg class="fp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          <span>Fast U.S. Shipping</span>
        </li>
        <li class="fp-trust__item">
          <svg class="fp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <span>Secure Checkout</span>
        </li>
        <li class="fp-trust__item">
          <svg class="fp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>
          <span>Easy Returns</span>
        </li>
        <li class="fp-trust__item">
          <svg class="fp-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          <span>Pet-Friendly Travel Essentials</span>
        </li>
      </ul>
    </div>

    {%- comment -%} Col 5 — Newsletter (right) {%- endcomment -%}
    {%- if section.settings.newsletter_enable -%}
      <div class="fp-col fp-newsletter fp-newsletter--right">
        <div class="fp-newsletter__inner">
          <h2 class="fp-newsletter__title">Get 15% Off Your First Order</h2>
          <p class="fp-newsletter__subtitle">Get updates on new products, promotion offers.</p>
          {%- form 'customer', id: 'ContactFooter', class: 'newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="fp-newsletter__form">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="fp-newsletter__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}autofocus aria-invalid="true" aria-describedby="ContactFooter-error"{% elsif form.posted_successfully? %}aria-describedby="ContactFooter-success"{% endif %}
                placeholder="Your email address"
                required
              >
              <button type="submit" class="fp-newsletter__btn" name="commit" aria-label="Subscribe">Subscribe</button>
            </div>
            <p class="fp-newsletter__disclaimer">By entering your email address, you agree to our Privacy Policy and will receive BaystoryBag offers, promotions and other commercial messages. You may unsubscribe at any time.</p>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="ContactFooter-error">{% render 'icon-error' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>{% render 'icon-success' %}{{ 'newsletter.success' | t }}</h3>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ─── Bottom Bar ─── {%- endcomment -%}
  <div class="fp-bottom">
    <div class="fp-bottom__copy">&copy; {{ 'now' | date: "%Y" }} <a href="{{ routes.root_url }}">BaystoryBag</a>. All Rights Reserved.</div>
  </div>
</footer>

{% javascript %}
  class LocalizationForm extends HTMLElement { constructor() { super(); } }
  customElements.define('localization-form', LocalizationForm);
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        { "type": "text", "id": "heading", "default": "Quick links", "label": "t:sections.footer.blocks.link_list.settings.heading.label" },
        { "type": "link_list", "id": "menu", "default": "footer", "label": "t:sections.footer.blocks.link_list.settings.menu.label", "info": "t:sections.footer.blocks.link_list.settings.menu.info" }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        { "type": "text", "id": "heading", "default": "Heading", "label": "t:sections.footer.blocks.text.settings.heading.label" },
        { "type": "richtext", "id": "subtext", "default": "<p>Share contact information, store details, and brand content with your customers.</p>", "label": "t:sections.footer.blocks.text.settings.subtext.label" }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "range", "id": "image_width", "min": 50, "max": 200, "step": 5, "unit": "px", "label": "Image width", "default": 100 },
        { "type": "select", "id": "alignment", "label": "Image alignment on large screen", "options": [{ "value": "", "label": "Left" },{ "value": "center", "label": "Center" },{ "value": "right", "label": "Right" }], "default": "center" }
      ]
    }
  ],
  "settings": [
    { "type": "select", "id": "color_scheme", "options": [{ "value": "accent-1", "label": "t:sections.all.colors.accent_1.label" },{ "value": "accent-2", "label": "t:sections.all.colors.accent_2.label" },{ "value": "background-1", "label": "t:sections.all.colors.background_1.label" },{ "value": "background-2", "label": "t:sections.all.colors.background_2.label" },{ "value": "inverse", "label": "t:sections.all.colors.inverse.label" }], "default": "background-1", "label": "t:sections.all.colors.label" },
    { "type": "header", "content": "t:sections.footer.settings.header__1.content", "info": "t:sections.footer.settings.header__1.info" },
    { "type": "checkbox", "id": "newsletter_enable", "default": true, "label": "t:sections.footer.settings.newsletter_enable.label" },
    { "type": "text", "id": "newsletter_heading", "default": "Subscribe to our emails", "label": "t:sections.footer.settings.newsletter_heading.label" },
    { "type": "header", "content": "t:sections.footer.settings.header__2.content", "info": "t:sections.footer.settings.header__2.info" },
    { "type": "checkbox", "id": "show_social", "default": false, "label": "t:sections.footer.settings.show_social.label" },
    { "type": "header", "content": "t:sections.footer.settings.header__3.content" },
    { "type": "checkbox", "id": "enable_country_selector", "default": false, "label": "t:sections.footer.settings.enable_country_selector.label" },
    { "type": "header", "content": "t:sections.footer.settings.header__5.content" },
    { "type": "checkbox", "id": "enable_language_selector", "default": false, "label": "t:sections.footer.settings.enable_language_selector.label" },
    { "type": "header", "content": "t:sections.footer.settings.header__7.content" },
    { "type": "checkbox", "id": "payment_enable", "default": true, "label": "t:sections.footer.settings.payment_enable.label" },
    { "type": "header", "content": "t:sections.all.spacing" },
    { "type": "range", "id": "margin_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "t:sections.footer.settings.margin_top.label", "default": 0 },
    { "type": "header", "content": "t:sections.all.padding.section_padding_heading" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "t:sections.all.padding.padding_top", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "t:sections.all.padding.padding_bottom", "default": 36 }
  ],
  "default": {
    "blocks": [{ "type": "link_list" },{ "type": "text" }]
  }
}
{% endschema %}