{%- comment -%}
  页面条幅(Page Banner)
  - 样机布局:棕色纹理底图(带水珠质感)+ 3 栏图标 + 文字
    默认项:EXPRESS DELIVERY / AVAILABLE CUSTOMER SERVICE / PAYMENT IN 3X
  - 每个图标项可由后台的 block 配置(图标图片 + 文字 + 链接)
  - 也支持"只显示一张图片"的简化模式(若未配置 block)
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} .page-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color | default: '#5b3d2f' }};
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {%- if section.settings.bg_image != blank -%}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2400 }}');
    {%- endif -%}
    color: {{ section.settings.text_color | default: '#ffffff' }};
  }
  #shopify-section-{{ section.id }} .page-banner::before {
    content: '';
    position: absolute; inset: 0;
    background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }
  #shopify-section-{{ section.id }} .page-banner__inner {
    position: relative;
    z-index: 2;
    {%- if section.settings.full_bleed -%}
      max-width: 100%;
      padding: 48px 40px;
    {%- else -%}
      max-width: 1440px;
      margin: 0 auto;
      padding: 48px;
    {%- endif -%}
  }
  #shopify-section-{{ section.id }} .page-banner__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_least: 1 }}, 1fr);
    gap: 32px;
    align-items: center;
  }
  @media (max-width: 720px) {
    #shopify-section-{{ section.id }} .page-banner__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
  .page-banner__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    color: inherit;
    text-decoration: none;
  }
  .page-banner__icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .page-banner__icon img, .page-banner__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    color: currentColor;
  }
  .page-banner__label {
    font-size: 15px;
    letter-spacing: .12em;
    font-weight: 600;
    text-transform: uppercase;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .page-banner__single {
    display: block;
  }
  #shopify-section-{{ section.id }} .page-banner__single img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>

<section class="page-banner">
  <div class="page-banner__inner">
    {%- if section.blocks.size > 0 -%}
      <div class="page-banner__grid">
        {%- for block in section.blocks -%}
          {%- assign icon = block.settings.icon -%}
          <a class="page-banner__item"
             href="{{ block.settings.url | default: '#' }}"
             {{ block.shopify_attributes }}>
            <span class="page-banner__icon">
              {%- if icon != blank -%}
                {{ icon | image_url: width: 120 | image_tag: loading: 'lazy', widths: '44,88,120', alt: block.settings.label }}
              {%- else -%}
                {%- case block.settings.icon_preset -%}
                  {%- when 'delivery' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 14l18-8 18 8-18 8zM6 14v20l18 8M42 14v20l-18 8M6 14l18 8 18-8M24 22v20M30 18l-12 6"/><path d="M30 28l4 2 6-4" stroke="currentColor" stroke-width="1.6"/></svg>
                  {%- when 'chat' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 10h22a4 4 0 0 1 4 4v14a4 4 0 0 1-4 4H18l-8 6V14a4 4 0 0 1 4-4z"/><circle cx="18" cy="21" r="1.5" fill="currentColor"/><circle cx="24" cy="21" r="1.5" fill="currentColor"/><circle cx="30" cy="21" r="1.5" fill="currentColor"/></svg>
                  {%- when 'card' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="12" width="36" height="24" rx="3"/><path d="M6 20h36M12 30h6"/></svg>
                  {%- else -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="16"/></svg>
                {%- endcase -%}
              {%- endif -%}
            </span>
            {%- if block.settings.label != blank -%}
              <p class="page-banner__label">{{ block.settings.label | escape }}</p>
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    {%- elsif section.settings.image != blank -%}
      {%- if section.settings.link != blank -%}
        <a class="page-banner__single" href="{{ section.settings.link }}" aria-label="{{ section.settings.alt | default: 'banner' }}">
      {%- endif -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'lazy', widths: '600,900,1200,1600,2000,2400', alt: section.settings.alt }}
      {%- if section.settings.link != blank -%}
        </a>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "页面条幅",
  "class": "section-page-banner",
  "max_blocks": 6,
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "背景图(棕色纹理/水珠等)" },
    { "type": "color", "id": "bg_color", "label": "背景兜底色", "default": "#5b3d2f" },
    { "type": "range", "id": "overlay_opacity", "label": "遮罩透明度(%)", "min": 0, "max": 80, "step": 5, "default": 0 },
    { "type": "color", "id": "text_color", "label": "文字颜色", "default": "#ffffff" },
    { "type": "header", "content": "兜底图片模式(当未添加任何图标块时生效)" },
    { "type": "image_picker", "id": "image", "label": "条幅图片" },
    { "type": "text", "id": "alt", "label": "图片说明文字" },
    { "type": "url", "id": "link", "label": "条幅链接" },
    { "type": "checkbox", "id": "full_bleed", "label": "满屏显示", "default": true },
    { "type": "range", "id": "padding_top", "label": "上内边距(px)", "min": 0, "max": 160, "step": 4, "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "下内边距(px)", "min": 0, "max": 160, "step": 4, "default": 48 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "图标+文字项",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "图标图片(留空则用内置图标)" },
        { "type": "select", "id": "icon_preset", "label": "内置图标", "options": [
          { "value": "delivery", "label": "配送/包裹" },
          { "value": "chat", "label": "客服/对话" },
          { "value": "card", "label": "支付/卡片" },
          { "value": "circle", "label": "圆形(默认)" }
        ], "default": "delivery" },
        { "type": "text", "id": "label", "label": "文字", "default": "EXPRESS DELIVERY" },
        { "type": "url", "id": "url", "label": "链接" }
      ]
    }
  ],
  "presets": [
    {
      "name": "页面条幅",
      "blocks": [
        { "type": "feature", "settings": { "icon_preset": "delivery", "label": "EXPRESS DELIVERY" } },
        { "type": "feature", "settings": { "icon_preset": "chat", "label": "AVAILABLE CUSTOMER SERVICE" } },
        { "type": "feature", "settings": { "icon_preset": "card", "label": "PAYMENT IN 3X" } }
      ]
    }
  ]
}
{% endschema %}
